GOOGLE_CREDENTIALS_PATH=./credentials/google_service_account.json
GOOGLE_CALENDAR_IDS=cal1@group.calendar.google.com,cal2@group.calendar.google.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_SMS_NUMBER=+15551234567
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=reminders@yourdomain.com
SENDGRID_FROM_NAME=Your Company
WEBHOOK_BASE_URL=https://hooks.yourdomain.com
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DB_PATH=./storage.sqlite
LOG_LEVEL=INFO
TZ=America/New_York

# ── ClickUp Webhook ────────────────────────────────────────────────────────
# Secret used for HMAC-SHA256 signature verification on incoming webhooks.
# Set this to the secret you configure in the ClickUp webhook settings.
CLICKUP_WEBHOOK_SECRET=
CLICKUP_API_TOKEN=

# ClickUp Custom Field IDs for the ACTIVE HVAC list (901317175958)
# Find these by running: python get_fields.py
CLICKUP_LIST_ID=901317175958

# Core customer fields
CLICKUP_FIELD_NAME=       # ⭐ Full Name
CLICKUP_FIELD_PHONE=      # ⭐ Phone
CLICKUP_FIELD_EMAIL=      # ⭐ Email

# Service type (multi-select — maps to appointment_type)
CLICKUP_FIELD_SCOPE=      # ⭐ Scope Of Work (Complete)

# Service-specific date fields
CLICKUP_FIELD_DATE_HVAC=        # ❄️ Installation Start Date   (Heat Pump, HVAC, Mini-Split, AC, Air Handler)
CLICKUP_FIELD_DATE_INSULATION=  # ❄️ Insulation Date           (Insulation, Attic, Wall, Basement)
CLICKUP_FIELD_DATE_ELECTRICAL=  # ⭐ Electrical Date            (Electrical, Main Panel, EV Charger)
CLICKUP_FIELD_DATE_ASSESSMENT=  # ❄️ Assessment Date           (Energy Assessment)
CLICKUP_FIELD_DATE_REMEDIATION= # ⭐ Remediation Date          (Vermiculite, Asbestos, Mold)
CLICKUP_FIELD_DATE_SOLAR=       # ⭐ Install Date              (Solar)
CLICKUP_FIELD_DATE_ROOF=        # ✅ Site Visit Date           (Roof, Roof Repair, Roof Replacement)

# Payment method — internal only, never shown to customers
CLICKUP_FIELD_PROGRAM=    # ❄️ HVAC Program

# ── Session Auth (Phase 4) ─────────────────────────────────────────────────
# --- Security & Auth ---
# Required: 32+ char random string for signing session cookies
SESSION_SECRET_KEY=change_me_to_a_secure_random_string

# Required: Comma-separated list of trusted proxy IPs (for X-Forwarded-For)
TRUSTED_PROXY_IPS=127.0.0.1
SESSION_SECURE_COOKIE=false
SESSION_MAX_AGE_SECONDS=28800

# ── DEPRECATED (Phase 3 — no longer used) ──────────────────────────────────
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=changeme